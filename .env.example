MCP_TRANSPORT=stdio
PORT=8787
HOST=127.0.0.1
ALLOWED_HOSTS=localhost,127.0.0.1,[::1]
LOG_LEVEL=info

# Optional OAuth 2.1 Bearer-token gate for HTTP transport (RFC 9068 + RFC 8707).
# Default `none` is fine for HOST=127.0.0.1; set `bearer` for any non-localhost
# deployment. When `bearer`, ISSUER and AUDIENCE are required.
MCP_AUTH_MODE=none
# MCP_AUTH_ISSUER=https://login.example.com/
# MCP_AUTH_AUDIENCE=https://mtender-mcp.example.com/mcp
# MCP_AUTH_JWKS_URL=                            # optional; auto-discovered from issuer if unset
# MCP_AUTH_REQUIRED_SCOPES=mcp:read
