{
  "name": "mtender-mcp-server",
  "version": "3.1.0",
  "description": "Modern MCP server for Moldova's MTender public procurement data (OCDS).",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "mtender-mcp": "./build/index.js"
  },
  "files": [
    "build"
  ],
  "scripts": {
    "build": "tsc && node -e \"import('node:fs').then(({chmodSync}) => chmodSync('build/index.js', 0o755))\"",
    "dev": "tsx watch src/index.ts",
    "start": "node build/index.js",
    "test": "node --test --import tsx test/**/*.test.ts",
    "inspector": "npx @modelcontextprotocol/inspector node build/index.js",
    "prepare": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "express": "^5.2.1",
    "mammoth": "^1.12.0",
    "pino": "^10.0.0",
    "sharp": "^0.34.5",
    "undici": "^8.1.0",
    "unpdf": "^1.6.2",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.0",
    "tsx": "^4.20.0",
    "typescript": "^5.7.0"
  }
}
